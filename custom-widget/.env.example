# ElevenLabs Voice Agent Configuration
# These variables are used during widget build time

# ElevenLabs Agent ID (required for voice feature)
VITE_ELEVENLABS_AGENT_ID=agent_6601kc1fqeecfc88s7d52jde0syq

# ElevenLabs Voice ID (optional - uses default if not specified)
VITE_ELEVENLABS_VOICE_ID=

# ElevenLabs Agent Name (displayed in UI)
VITE_ELEVENLABS_AGENT_NAME=AI Assistant

# n8n Webhook Configuration
# URL where prechat form submissions will be sent (silent, no message in chat)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chatwoot-form
